{
  "rewrites": [
    { "source": "/api/health", "destination": "/api/index.ts" },
    { "source": "/api/test", "destination": "/api/test.ts" },
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/((?!api|assets|favicon.ico|icon.png).*)", "destination": "/index.html" }
  ]
}
